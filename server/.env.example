# ── База данных ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aniverse
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────
# Сгенерируй случайную строку: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# ── Сервер ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS: разрешённый origin фронтенда ──────────────────────
# Локально: http://localhost:5173
# Продакшн: https://yourdomain.com
CLIENT_ORIGIN=http://localhost:5173

# ── Connection Pool ───────────────────────────────────────────
DB_POOL_MAX=10
DB_IDLE_MS=30000
DB_CONN_TIMEOUT_MS=5000
# SSL для облачных БД (Supabase, Neon, Railway):
DB_SSL=false
